rules_version = '2';

// Emergency recall check-in app. Single top-level `checkins` collection.
// Any authenticated user can read (needed for the roster view) and create
// check-ins for themselves. Check-ins are immutable and non-deletable from
// the client — fix history via the Firebase console if ever needed.
//
// Deploy: `firebase deploy --only firestore:rules` (requires firebase-tools
// and a `firebase.json` that references this file), or paste the contents
// into Firestore -> Rules in the Firebase console.

service cloud.firestore {
  match /databases/{database}/documents {

    match /checkins/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly(
             ['uid', 'email', 'displayName', 'status', 'note', 'timestamp']
           )
        && request.resource.data.keys().hasAll(
             ['uid', 'email', 'displayName', 'status', 'note', 'timestamp']
           )
        && request.resource.data.status in ['available', 'unavailable', 'onleave']
        && request.resource.data.displayName is string
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 500
        && request.resource.data.timestamp == request.time;

      allow update, delete: if false;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
